<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .table-hover tbody tr:hover { cursor: pointer; background-color: #f8f9fa; }
        .cart-container { height: 70vh; display: flex; flex-direction: column; }
        #cart-items { flex-grow: 1; overflow-y: auto; }


        /* Modal Box Print (reports.ejs) */
        @media print {
            /* တစ်မျက်နှာလုံးမှာ ရှိသမျှ အကုန်ဖျောက်မယ် */
            body * {
                visibility: hidden;
            }
            /* Modal နဲ့ သူ့အထဲက အစိတ်အပိုင်းတွေကိုပဲ ပြန်ပြမယ် */
            #voucherModal, #voucherModal * {
                visibility: visible;
            }
            /* Modal ကို စာမျက်နှာရဲ့ ထိပ်ဆုံး အစွန်းကို ကပ်ထုတ်မယ် */
            #voucherModal {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                margin: 0;
                padding: 0;
            }
            /* မလိုအပ်တဲ့ Close/Print Button တွေကို Print ထဲမှာ ဖျောက်ထားမယ် */
            .modal-header, .modal-footer, .btn-close {
                display: none !important;
            }
        
            .modal-content {
                border: none !important;
                box-shadow: none !important;
            }
            .modal-header {
                border-bottom: 2px solid #000 !important;
                background-color: transparent !important;
                color: #000 !important;
            }
            /* စာသားအရောင်တွေကို အမည်းရောင် ပိုတောက်အောင်ထားမယ် */
            .text-muted {
                color: #000 !important;
            }
        }
    </style>
</head>
<body class="bg-light">