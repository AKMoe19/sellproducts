<%- include('partials/header') %>

<style>
    .stat-card {
        transition: transform 0.3s;
        border-radius: 15px;
    }
    .stat-card:hover {
        transform: translateY(-5px);
    }
    .icon-shape {
        width: 48px;
        height: 48px;
        background-color: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }
    /* Active Button Style */
    .btn-group .btn.active {
        background-color: #0d6efd !important;
        color: white !important;
        border-color: #0d6efd !important;
        font-weight: bold;
        z-index: 2;
    }
    /* Sticky table header */
    .table-responsive {
        scrollbar-width: thin;
    }
</style>

<nav class="navbar navbar-dark bg-dark mb-4 shadow-sm">
    <div class="container-fluid">
        <span class="navbar-brand fw-bold"><i class="fas fa-chart-line me-2 text-info"></i> Business Analytics</span>
        <a href="/admin" class="btn btn-outline-light btn-sm">Back to Admin</a>
    </div>
</nav>

<div class="container pb-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h4 class="fw-bold mb-0">Sales Overview</h4>
            <p class="text-muted small">Track your revenue and performance</p>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group shadow-sm" id="analyticsToggle">
                <button type="button" id="btn-daily" class="btn btn-white border" onclick="updateChart('daily')">Daily</button>
                <button type="button" id="btn-monthly" class="btn btn-white border active" onclick="updateChart('monthly')">Monthly</button>
                <button type="button" id="btn-yearly" class="btn btn-white border" onclick="updateChart('yearly')">Yearly</button>
            </div>

            <select id="yearSelect" class="form-select d-inline-block w-auto ms-2 border shadow-sm" onchange="refreshCurrentView()">
                <% 
                    const currentYear = new Date().getFullYear(); 
                    const startYear = 2024; 
                    for(let y = currentYear; y >= startYear; y--) { 
                %>
                    <option value="<%= y %>" <%= y === currentYear ? 'selected' : '' %>><%= y %></option>
                <% } %>
            </select>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card card bg-primary text-white border-0 shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape me-3"><i class="fas fa-money-bill-wave fa-lg"></i></div>
                    <div>
                        <p class="mb-0 small opacity-75">Total Revenue</p>
                        <h3 class="fw-bold mb-0" id="totalRevenue">0 <small class="fs-6">MMK</small></h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card card bg-info text-white border-0 shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape me-3"><i class="fas fa-shopping-cart fa-lg"></i></div>
                    <div>
                        <p class="mb-0 small opacity-75">Total Sales</p>
                        <h3 class="fw-bold mb-0" id="totalSales">0</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card card bg-success text-white border-0 shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape me-3"><i class="fas fa-chart-bar fa-lg"></i></div>
                    <div>
                        <p class="mb-0 small opacity-75">Avg per Order</p>
                        <h3 class="fw-bold mb-0" id="avgOrder">0 <small class="fs-6">MMK</small></h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="mb-0 fw-bold text-dark" id="chartTitle">Revenue Trend</h6>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="mb-0 fw-bold text-dark" id="tableTitle">Breakdown Details</h6>
                </div>
                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th id="periodColumnTitle">Period</th>
                                <th class="text-end">Revenue</th>
                            </tr>
                        </thead>
                        <tbody id="statsTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let myChart;
    let currentType = 'monthly';
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

    function refreshCurrentView() {
        updateChart(currentType);
    }

    async function updateChart(type) {
        currentType = type;
        const yearSelect = document.getElementById('yearSelect');
        const selectedYear = yearSelect.value;
        
        // Active Button UI Logic
        document.querySelectorAll('#analyticsToggle .btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById(`btn-${type}`).classList.add('active');

        // Yearly ဆိုရင် dropdown ကို disable လုပ်ထားမယ် (ဘာလို့ဆို ရှိသမျှနှစ်အားလုံးပြမှာမို့လို့)
        if (type === 'yearly') {
            yearSelect.disabled = true;
            yearSelect.style.opacity = '0.5';
        } else {
            yearSelect.disabled = false;
            yearSelect.style.opacity = '1';
        }

        // Fetch Data from API
        // Yearly ဖြစ်ရင် year parameter မထည့်တော့ဘူး (Backend က အားလုံးပြန်ပေးအောင်)
        const url = type === 'yearly' ? `/api/analytics?type=${type}` : `/api/analytics?type=${type}&year=${selectedYear}`;
        const res = await fetch(url);
        const data = await res.json();

        if (data.success) {
            const stats = data.stats;
            let labels = [];
            let chartDataArray = [];
            let totalRev = 0;
            let totalCount = 0;

            // 1. Logic for Labels & Chart Data
            if (type === 'monthly') {
                labels = months;
                chartDataArray = new Array(12).fill(0);
                stats.forEach(s => {
                    chartDataArray[s._id - 1] = s.totalRevenue;
                    totalRev += s.totalRevenue;
                    totalCount += s.orderCount;
                });
                document.getElementById('chartTitle').innerText = `Monthly Revenue Trend (${selectedYear})`;
                document.getElementById('periodColumnTitle').innerText = "Month";
            } 
            else if (type === 'daily') {
                labels = stats.map(s => `Day ${s._id}`);
                chartDataArray = stats.map(s => s.totalRevenue);
                stats.forEach(s => {
                    totalRev += s.totalRevenue;
                    totalCount += s.orderCount;
                });
                document.getElementById('chartTitle').innerText = `Daily Revenue Trend (Current Month)`;
                document.getElementById('periodColumnTitle').innerText = "Date";
            } 
            else if (type === 'yearly') {
                // ရှိသမျှ နှစ်တွေအလိုက် Sort စီမယ်
                stats.sort((a, b) => a._id - b._id);
                labels = stats.map(s => s._id);
                chartDataArray = stats.map(s => s.totalRevenue);
                stats.forEach(s => {
                    totalRev += s.totalRevenue;
                    totalCount += s.orderCount;
                });
                document.getElementById('chartTitle').innerText = "Overall Yearly Revenue Trend";
                document.getElementById('periodColumnTitle').innerText = "Year";
            }

            // 2. Update Summary Cards
            document.getElementById('totalRevenue').innerText = totalRev.toLocaleString();
            document.getElementById('totalSales').innerText = totalCount.toLocaleString();
            document.getElementById('avgOrder').innerText = totalCount > 0 ? Math.round(totalRev / totalCount).toLocaleString() : 0;

            // 3. Update Table Body
            const tableBody = document.getElementById('statsTableBody');
            tableBody.innerHTML = stats.map(s => `
                <tr>
                    <td>${type === 'monthly' ? months[s._id-1] : (type === 'yearly' ? s._id : 'Day ' + s._id)}</td>
                    <td class="text-end fw-bold text-primary">${s.totalRevenue.toLocaleString()}</td>
                </tr>
            `).reverse().join(''); // table မှာ အသစ်ဆုံး (နှစ်/ရက်) ကို အပေါ်ကပြဖို့ reverse() သုံးထားတယ်

            // 4. Update Chart.js
            if (myChart) myChart.destroy();
            const ctx = document.getElementById('salesChart').getContext('2d');
            myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue',
                        data: chartDataArray,
                        borderColor: '#4e54c8',
                        backgroundColor: 'rgba(78, 84, 200, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#4e54c8'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { 
                        y: { 
                            beginAtZero: true,
                            ticks: { callback: (val) => val.toLocaleString() }
                        } 
                    }
                }
            });
        }
    }

    // Initial load
    window.onload = () => updateChart('monthly');
</script>

<%- include('partials/footer') %>
