<%- include('partials/header') %>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
    <div class="container-fluid">
        <span class="navbar-brand fw-bold"><i class="fas fa-user-shield me-2"></i> Admin Dashboard</span>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNavbar">
            <div class="navbar-nav ms-auto align-items-center">
                <a href="/" class="btn btn-outline-light btn-sm me-2"><i class="fas fa-home me-1"></i> Home</a>
                <a href="/analytics" class="btn btn-outline-info btn-sm me-2"><i class="fas fa-chart-line me-1"></i> Analytics</a>
                <a href="/logout" class="btn btn-outline-danger btn-sm my-1"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h4 class="fw-bold mb-0 text-dark">Management Center</h4>
        </div>
        <div class="col-auto">
            <button type="button" class="btn btn-primary shadow-sm px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#addProductModal" onclick="resetProductForm()">
                <i class="fas fa-plus-circle me-1"></i> Add New Product
            </button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white py-3">
                    <span class="fw-bold small text-uppercase"><i class="fas fa-users me-2"></i> User Management</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                <tr>
                                    <td><div class="fw-bold text-dark"><%= u.username %></div></td>
                                    <td>
                                        <span class="badge <%= u.role === 'admin' ? 'bg-info' : 'bg-secondary' %> opacity-75 fw-normal">
                                            <%= u.role.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-light text-primary border shadow-sm" onclick="openUserModal('<%= u._id %>', '<%= u.username %>', '<%= u.role %>')">
                                            <i class="fas fa-user-cog"></i> Settings
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-primary text-white overflow-hidden">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-center position-relative" style="z-index: 2;">
                        <div>
                            <h6 class="text-uppercase small fw-bold mb-1 opacity-75">Total Inventory Value</h6>
                            <h3 class="fw-bold mb-0"><%= (typeof totalValue !== 'undefined' ? totalValue : 0).toLocaleString() %> <small class="fs-6">MMK</small></h3>
                            <p class="small mb-0 mt-2 opacity-75">* လက်ရှိပစ္စည်းများ၏ စုစုပေါင်းတန်ဖိုး</p>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-circle p-3">
                            <i class="fas fa-wallet fa-2x"></i>
                        </div>
                    </div>
                    <i class="fas fa-calculator position-absolute bottom-0 end-0 p-3 opacity-25 fa-5x text-white" style="margin-bottom: -20px; margin-right: -10px;"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <span class="fw-bold text-primary"><i class="fas fa-boxes me-2"></i> Product Inventory</span>
                    <div class="input-group" style="max-width: 250px;">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="productSearch" class="form-control bg-light border-0" onkeyup="searchProduct()" placeholder="Search products...">
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 650px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0" id="productTable">
                            <thead class="table-light sticky-top">
                                <tr class="small text-uppercase text-muted">
                                    <th>Product Details</th>
                                    <th class="text-danger">Cost (ဝယ်ဈေး)</th>
                                    <th class="text-success">Price (ရောင်းဈေး)</th>
                                    <th>Stock</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(p => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="<%= p.image %>" onerror="this.src='/images/default-product.png'" class="rounded border shadow-sm me-3" width="45" height="45" style="object-fit: cover;">
                                            <div>
                                                <div class="product-name fw-bold text-dark text-truncate" style="max-width: 180px;"><%= p.name %></div>
                                                <small class="text-muted text-uppercase" style="font-size: 0.65rem;">ID: <%= p._id.toString().slice(-6) %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="fw-bold text-danger"><%= (p.costPrice || 0).toLocaleString() %> <small>MMK</small></td>
                                    <td class="fw-bold text-success"><%= p.price.toLocaleString() %> <small>MMK</small></td>
                                    <td>
                                        <span class="badge <%= p.stock < 10 ? 'bg-danger pulse' : 'bg-success' %> rounded-pill px-3 py-2">
                                            <%= p.stock %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-warning border-0 me-1" 
                                                onclick="editProduct('<%= p._id %>', '<%= p.name %>', <%= p.price %>, <%= p.stock %>, '<%= p.image %>', <%= p.costPrice || 0 %>)">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <a href="/admin/delete-product/<%= p._id %>" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('ဒီပစ္စည်းကို ဖျက်မှာ သေချာပါသလား?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold" id="productModalTitle"><i class="fas fa-plus-circle me-2"></i> Add New Product</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="product-form" action="/admin/add-product" method="POST" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="prod-id">
                    
                    <div class="mb-4 text-center">
                        <div class="position-relative d-inline-block mb-2">
                            <img id="current-prod-image" src="/images/default-product.png" class="rounded shadow-sm border" width="120" height="120" style="object-fit: cover;">
                            <label for="prod-image" class="position-absolute bottom-0 end-0 bg-dark text-white rounded-circle p-2 border border-white" style="cursor: pointer; width: 35px; height: 35px; line-height: 20px;">
                                <i class="fas fa-camera fa-xs"></i>
                            </label>
                        </div>
                        <input type="file" name="image" id="prod-image" class="d-none" accept="image/*" onchange="previewImage(this)">
                        <small class="text-muted d-block mt-1">Product Image (PNG, JPG)</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Product Name</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-muted"></i></span>
                            <input type="text" name="name" id="prod-name" class="form-control border-start-0" required placeholder="Enter product name">
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold text-danger text-uppercase">Cost Price (ဝယ်ဈေး)</label>
                            <input type="number" name="costPrice" id="prod-costPrice" class="form-control shadow-sm" required placeholder="0">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold text-success text-uppercase">Sale Price (ရောင်းဈေး)</label>
                            <input type="number" name="price" id="prod-price" class="form-control shadow-sm" required placeholder="0">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Initial Stock</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-cubes text-muted"></i></span>
                            <input type="number" name="stock" id="prod-stock" class="form-control border-start-0" required placeholder="0">
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-dark text-white border-0 py-3">
                <h6 class="modal-title fw-bold"><i class="fas fa-user-cog me-2"></i> User Settings</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/edit-user" method="POST">
                <div class="modal-body p-4 text-center">
                    <input type="hidden" name="userId" id="modal-userId">
                    <div class="bg-light d-inline-block p-3 rounded-circle border mb-3">
                        <i class="fas fa-user-circle fa-3x text-secondary"></i>
                    </div>
                    <h5 id="modal-username-display" class="fw-bold text-primary mb-4"></h5>
                    
                    <div class="mb-3 text-start">
                        <label class="small fw-bold text-muted mb-1 text-uppercase">Assign Role</label>
                        <select name="newRole" id="modal-role" class="form-select shadow-sm">
                            <option value="admin">Admin</option>
                            <option value="cashier">Cashier</option>
                        </select>
                    </div>
                    <div class="mb-1 text-start">
                        <label class="small fw-bold text-muted mb-1 text-uppercase">Update Password</label>
                        <input type="password" name="newPassword" class="form-control shadow-sm" placeholder="Leave blank to keep current">
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button type="submit" class="btn btn-dark w-100 shadow-sm fw-bold py-2">Update User Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .pulse { animation: pulse-red 2s infinite; }
    @keyframes pulse-red {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }
</style>

<script>
    function searchProduct() {
        const input = document.getElementById('productSearch');
        const filter = input.value.toUpperCase();
        const tr = document.querySelectorAll("#productTable tbody tr");

        tr.forEach(row => {
            const nameTd = row.querySelector('.product-name');
            if (nameTd) {
                const text = nameTd.textContent || nameTd.innerText;
                row.style.display = text.toUpperCase().includes(filter) ? "" : "none";
            }
        });
    }

    function editProduct(id, name, price, stock, image, costPrice) {
        document.getElementById('productModalTitle').innerHTML = '<i class="fas fa-edit me-2"></i> Edit Product Information';
        document.getElementById('product-form').action = "/admin/edit-product";
        document.getElementById('prod-id').value = id;
        document.getElementById('prod-name').value = name;
        document.getElementById('prod-price').value = price;
        document.getElementById('prod-stock').value = stock;
        document.getElementById('prod-costPrice').value = costPrice;

        const currentImg = document.getElementById('current-prod-image');
        currentImg.src = (image && image !== 'undefined' && image !== '') ? image : '/images/default-product.png';

        const myModal = new bootstrap.Modal(document.getElementById('addProductModal'));
        myModal.show();
    }

    function resetProductForm() {
        document.getElementById('productModalTitle').innerHTML = '<i class="fas fa-plus-circle me-2"></i> Add New Product';
        document.getElementById('product-form').action = "/admin/add-product";
        document.getElementById('product-form').reset();
        document.getElementById('prod-id').value = '';
        document.getElementById('current-prod-image').src = '/images/default-product.png';
    }

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('current-prod-image').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }

    function openUserModal(id, name, role) {
        document.getElementById('modal-userId').value = id;
        document.getElementById('modal-username-display').innerText = name;
        document.getElementById('modal-role').value = role.toLowerCase();
        const myModal = new bootstrap.Modal(document.getElementById('userModal'));
        myModal.show();
    }
</script>

<%- include('partials/footer') %>