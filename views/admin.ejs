<%- include('partials/header') %>

<nav class="navbar navbar-dark bg-dark shadow-sm mb-4">
    <div class="container-fluid">
        <span class="navbar-brand fw-bold"><i class="fas fa-user-shield me-2"></i> Admin Dashboard</span>
        <div class="d-flex align-items-center">
            <a href="/" class="btn btn-outline-light btn-sm me-2"><i class="fas fa-home me-1"></i> Home</a>
            <a href="/analytics" class="btn btn-outline-info btn-sm me-2"><i class="fas fa-chart-line me-1"></i> Analytics</a>
            <a href="/logout" class="btn btn-outline-danger btn-sm my-1"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark">Management Center</h4>
        <button type="button" class="btn btn-primary shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#addProductModal" onclick="resetProductForm()">
            <i class="fas fa-plus-circle me-1"></i> Add New Product
        </button>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <span class="fw-bold small text-uppercase"><i class="fas fa-users me-2"></i> User Management</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                <tr>
                                    <td><div class="fw-bold text-dark"><%= u.username %></div></td>
                                    <td>
                                        <span class="badge <%= u.role === 'admin' ? 'bg-info' : 'bg-secondary' %> opacity-75 fw-normal" style="font-size: 0.7rem;">
                                            <%= u.role.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-link text-primary p-0 me-2 text-decoration-none" onclick="openUserModal('<%= u._id %>', '<%= u.username %>', '<%= u.role %>')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <span class="fw-bold text-primary"><i class="fas fa-boxes me-2"></i> Product Inventory</span>
                    <div class="input-group" style="max-width: 250px;">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="productSearch" class="form-control bg-light border-0" onkeyup="searchProduct()" placeholder="Search products...">
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0" id="productTable">
                            <thead class="table-light sticky-top">
                                <tr class="small text-uppercase text-muted">
                                    <th>Product Details</th>
                                    <th class="text-danger">Cost (ဝယ်ဈေး)</th>
                                    <th class="text-success">Price (ရောင်းဈေး)</th>
                                    <th>Stock</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(p => { %>
                                <tr>
                                    <td class="fw-bold text-dark">
                                        <div class="d-flex align-items-center">
                                            <img src="<%= p.image %>" onerror="this.src='/images/default-product.png'" class="rounded border shadow-sm me-3" width="40" height="40" style="object-fit: cover;">
                                            <span class="product-name"><%= p.name %></span>
                                        </div>
                                    </td>
                                    <td class="fw-bold text-danger"><%= p.costPrice ? p.costPrice.toLocaleString() : 0 %> <small>MMK</small></td>
                                    <td class="fw-bold text-success"><%= p.price.toLocaleString() %> <small>MMK</small></td>
                                    <td>
                                        <span class="badge <%= p.stock < 10 ? 'bg-danger' : 'bg-success' %> rounded-pill px-3">
                                            <%= p.stock %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-warning border-0" 
                                                onclick="editProduct('<%= p._id %>', '<%= p.name %>', <%= p.price %>, <%= p.stock %>, '<%= p.image %>', <%= p.costPrice || 0 %>)">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <a href="/admin/delete-product/<%= p._id %>" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('Delete item?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold" id="productModalTitle"><i class="fas fa-plus-circle me-2"></i> Add New Product</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="product-form" action="/admin/add-product" method="POST" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="prod-id">
                    
                    <div class="mb-4 text-center">
                        <div class="mb-2">
                            <img id="current-prod-image" src="/images/default-product.png" class="rounded shadow-sm border" width="100" height="100" style="object-fit: cover;">
                        </div>
                        <label class="form-label small fw-bold text-muted d-block text-start">Product Image</label>
                        <input type="file" name="image" id="prod-image" class="form-control shadow-sm" accept="image/*" onchange="previewImage(this)">
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Product Name</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-light"><i class="fas fa-tag"></i></span>
                            <input type="text" name="name" id="prod-name" class="form-control" required placeholder="Enter product name">
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold text-danger">Cost Price (ဝယ်ဈေး)</label>
                            <input type="number" name="costPrice" id="prod-costPrice" class="form-control shadow-sm" required placeholder="0">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold text-success">Sale Price (ရောင်းဈေး)</label>
                            <input type="number" name="price" id="prod-price" class="form-control shadow-sm" required placeholder="0.00">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Current Stock</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-light"><i class="fas fa-cubes"></i></span>
                            <input type="number" name="stock" id="prod-stock" class="form-control" required placeholder="0">
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Save Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-dark text-white border-0 py-3">
                <h6 class="modal-title fw-bold"><i class="fas fa-user-cog me-2"></i> User Settings</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/edit-user" method="POST">
                <div class="modal-body p-4">
                    <input type="hidden" name="userId" id="modal-userId">
                    <div class="text-center mb-3">
                        <div class="bg-light d-inline-block p-3 rounded-circle border mb-2">
                            <i class="fas fa-user-alt fa-2x text-secondary"></i>
                        </div>
                        <h6 id="modal-username-display" class="fw-bold text-primary"></h6>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-muted mb-1">Role</label>
                        <select name="newRole" id="modal-role" class="form-select shadow-sm">
                            <option value="admin">Admin</option>
                            <option value="cashier">Cashier</option>
                        </select>
                    </div>
                    <div class="mb-1">
                        <label class="small fw-bold text-muted mb-1">New Password</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Optional">
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button type="submit" class="btn btn-dark w-100 shadow-sm">Apply Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // --- Product Search Function ---
    function searchProduct() {
        const input = document.getElementById('productSearch');
        const filter = input.value.toUpperCase();
        const table = document.getElementById('productTable');
        const tr = table.getElementsByTagName('tr');

        for (let i = 1; i < tr.length; i++) {
            // Product Details column ထဲက name ကို ရှာမယ်
            const td = tr[i].getElementsByClassName('product-name')[0];
            if (td) {
                const txtValue = td.textContent || td.innerText;
                if (txtValue.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    // Edit Product Function
    function editProduct(id, name, price, stock, image, costPrice) {
        document.getElementById('productModalTitle').innerHTML = '<i class="fas fa-edit me-2"></i> Edit Product';
        document.getElementById('product-form').action = "/admin/edit-product";
        document.getElementById('prod-id').value = id;
        document.getElementById('prod-name').value = name;
        document.getElementById('prod-price').value = price;
        document.getElementById('prod-stock').value = stock;
        document.getElementById('prod-costPrice').value = costPrice;

        const currentImg = document.getElementById('current-prod-image');
        if (image && image !== 'undefined' && image !== '') {
            currentImg.src = image;
        } else {
            currentImg.src = '/images/default-product.png';
        }

        new bootstrap.Modal(document.getElementById('addProductModal')).show();
    }

    // Reset Form for New Entry
    function resetProductForm() {
        document.getElementById('productModalTitle').innerHTML = '<i class="fas fa-plus-circle me-2"></i> Add New Product';
        document.getElementById('product-form').action = "/admin/add-product";
        document.getElementById('product-form').reset();
        document.getElementById('prod-id').value = '';
        document.getElementById('prod-costPrice').value = '';
        document.getElementById('current-prod-image').src = '/images/default-product.png';
    }

    // Live Image Preview
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('current-prod-image').src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function openUserModal(id, name, role) {
        document.getElementById('modal-userId').value = id;
        document.getElementById('modal-username-display').innerText = name;
        document.getElementById('modal-role').value = role;
        new bootstrap.Modal(document.getElementById('userModal')).show();
    }
</script>

<%- include('partials/footer') %>