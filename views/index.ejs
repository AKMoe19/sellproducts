<%- include('partials/header') %>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="#"><i class="fas fa-shopping-basket me-2 text-warning"></i> SMART POS</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="ms-auto d-flex align-items-center flex-wrap">
                <span class="text-light me-3 small my-2"><i class="fas fa-user-circle me-1"></i> <%= user.username %></span>
                <a href="/admin" class="btn btn-outline-info btn-sm me-2 my-1"><i class="fas fa-cog"></i> Admin</a>
                <a href="/reports" class="btn btn-outline-light btn-sm me-2 my-1"><i class="fas fa-chart-line"></i> Reports</a>
                <a href="/logout" class="btn btn-danger btn-sm my-1"><i class="fas fa-sign-out-alt"></i></a>
            </div>
        </div>
    </div>
</nav>

<div class="container-fluid px-2 px-md-4">
    <div class="row g-3">
        <!-- Inventory List -->
        <div class="col-12 col-lg-8 col-md-7">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <h5 class="mb-2 mb-md-0 fw-bold text-primary">Inventory List</h5>
                    <div class="input-group" style="max-width: 300px;">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="productSearch" class="form-control bg-light border-0" onkeyup="searchProduct()" placeholder="Search products...">
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 550px;">
                    <table class="table table-hover align-middle mb-0" id="productTable">
                        <thead class="table-light sticky-top" style="z-index: 1;">
                            <tr class="text-muted small">                                
                                <th class="ps-4">Product</th>
                                <th>Price</th>
                                <th class="text-center">Stock</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach(p => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded p-1 me-2 d-none d-sm-block">
                                             <img src="<%= p.image || '/images/default-product.png' %>" width="30" height="30" class="rounded object-fit-cover" />
                                        </div>
                                        <span class="fw-bold small text-wrap" style="max-width: 120px;"><%= p.name %></span>
                                    </div>
                                </td>
                                <td class="small fw-bold"><%= p.price.toLocaleString() %></td>
                                <td class="text-center">
                                    <span id="stock-<%= p._id %>" class="badge rounded-pill <%= p.stock < 10 ? 'bg-danger' : 'bg-soft-info text-info border border-info' %>">
                                        <%= p.stock %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-primary btn-sm rounded-pill px-3" onclick="addToCart('<%= p._id %>', '<%= p.name %>', <%= p.price %>)">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Cart Section -->
        <div class="col-12 col-lg-4 col-md-5">
            <div class="card shadow border-0 rounded-3 sticky-md-top mb-5" style="top: 20px;">
                <div class="card-body p-3 p-md-4">
                    <h5 class="fw-bold mb-4 d-flex justify-content-between">
                        <span><i class="fas fa-shopping-cart me-2 text-primary"></i> Cart</span>
                        <span class="badge bg-primary rounded-pill small" id="cart-count">0</span>
                    </h5>
                    
                    <div id="cart-items-container" style="min-height: 150px; max-height: 300px; overflow-y: auto;">
                        <ul class="list-group list-group-flush" id="cart-items"></ul>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="small fw-bold text-muted">Disc (%)</label>
                                <input type="number" id="discount-input" class="form-control form-control-sm border-0 bg-light" value="0" min="0" oninput="updateCartUI()">
                            </div>
                            <div class="col-6">
                                <label class="small fw-bold text-muted">Tax (%)</label>
                                <input type="number" id="tax-input" class="form-control form-control-sm border-0 bg-light" value="0" min="0" oninput="updateCartUI()">
                            </div>
                        </div>

                        <div class="cart-summary-details">
                            <div class="d-flex justify-content-between mb-1 small">
                                <span class="text-muted">Subtotal:</span>
                                <span id="subtotal-display" class="fw-bold text-dark">0 MMK</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1 small text-danger">
                                <span>Discount:</span>
                                <span id="discount-display">- 0 MMK</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 small text-primary">
                                <span>Tax:</span>
                                <span id="tax-display">+ 0 MMK</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 border-top pt-2">
                                <h5 class="fw-bold mb-0">Total:</h5>
                                <h5 class="fw-bold mb-0 text-success" id="total-amount">0 MMK</h5>
                            </div>

                            <button class="btn btn-success btn-lg w-100 shadow-sm fw-bold mb-2" onclick="openPaymentModal()">
                                <i class="fas fa-check-double me-2"></i> CHECKOUT
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow border-0">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-wallet me-2"></i> Payment Method</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <label class="form-label fw-bold mb-3">ငွေပေးချေမှုစနစ် ရွေးချယ်ပါ</label>
                <div class="row g-3">
                    <!-- Cash အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-cash" value="Cash" checked>
                        <label class="btn btn-outline-success w-100 py-3" for="pay-cash">
                            <i class="fas fa-money-bill-wave d-block mb-2 fs-4"></i> Cash
                        </label>
                    </div>
                    <!-- Kpay အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-kpay" value="Kpay">
                        <label class="btn btn-outline-primary w-100 py-3" for="pay-kpay">
                            <i class="fas fa-mobile-alt d-block mb-2 fs-4"></i> Kpay
                        </label>
                    </div>
                    <!-- WavePay အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-wave" value="WavePay">
                        <label class="btn btn-outline-warning w-100 py-3" for="pay-wave">
                            <i class="fas fa-university d-block mb-2 fs-4"></i> WavePay
                        </label>
                    </div>
                    <!-- AYAPay အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-ayapay" value="AYAPay">
                        <label class="btn btn-outline-danger w-100 py-3" for="pay-ayapay">
                            <i class="fas fa-university d-block mb-2 fs-4"></i> AYAPay
                        </label>
                    </div>

                    <!-- CBPay အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-cbpay" value="CBPay">
                        <label class="btn btn-outline-info w-100 py-3" for="pay-cbpay">
                            <i class="fas fa-university d-block mb-2 fs-4"></i> CBPay
                        </label>
                    </div>
                    <!-- MMQR Pay အတွက် -->
                    <div class="col-6">
                        <input type="radio" class="btn-check" name="payType" id="pay-mmqr" value="MMQR">
                        <label class="btn btn-outline-info w-100 py-3" for="pay-mmqr">
                            <i class="fas fa-qrcode d-block mb-2 fs-4"></i> MMQR Pay
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-3 bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Close</button>
                <button type="button" onclick="confirmPayment()" class="btn btn-success px-4 shadow-sm fw-bold">Confirm & Receipt</button>
            </div>
        </div>
    </div>
</div>

<!-- Voucher Modal (Receipt) -->
<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content shadow border-0">
            <div id="printableReceipt" class="p-4 bg-white text-dark" style="font-family: 'Courier New', monospace; font-size: 13px;">
                <div class="text-center">
                    <h5 class="fw-bold mb-0">SMART POS SYSTEM</h5>
                    <p class="small mb-0">YANGON, MYANMAR</p>
                    
                    <!-- Voucher ID ကို ဒီနေရာမှာ ပြပေးမှာဖြစ်ပါတယ် -->
                    <p class="small fw-bold mb-0 text-uppercase">
                        Voucher ID: <span id="display-voucher-id">V-XXXXXXXX</span>
                    </p>
                    <p class="small" id="receipt-date"></p>
                </div>

                <div class="border-bottom border-dark border-1 border-dashed mb-2"></div>
                <div id="receipt-items"></div>
                <div class="border-bottom border-dark border-1 border-dashed my-2"></div>
                
                <div class="d-flex justify-content-between small">
                    <span>Subtotal:</span><span id="receipt-subtotal"></span>
                </div>
                <div class="d-flex justify-content-between small text-danger">
                    <span>Discount:</span><span id="receipt-discount"></span>
                </div>
                <div class="d-flex justify-content-between small text-primary">
                    <span>Tax:</span><span id="receipt-tax"></span>
                </div>
                <div class="d-flex justify-content-between fw-bold fs-6 mt-1 pt-1 border-top border-dark border-1 border-dashed">
                    <span>TOTAL:</span><span id="receipt-total"></span>
                </div>
                
                <div class="mt-2 small text-center border-top pt-2">
                    <span>Payment: <span id="receipt-paytype" class="fw-bold"></span></span>
                </div>
                <div class="mt-1 small text-center">
                    <span>Sold By: <span class="text-capitalize"><%= user.username %></span></span>
                </div>
                <div class="text-center mt-4">
                    <small>*** THANK YOU! ***</small>
                </div>
            </div>
            <div class="modal-footer border-0 p-3">
                <button type="button" class="btn btn-light btn-sm w-100 mb-2" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary btn-sm w-100" onclick="printReceipt()">Print Voucher</button>
            </div>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    var socket = io();
    let cart = [];

    // --- Cart Logic ---
    function addToCart(id, name, price) {
        const stockEl = document.getElementById(`stock-${id}`);
        const currentStock = stockEl ? parseInt(stockEl.innerText) : 0;
        const existingItem = cart.find(i => i.id === id);
        const currentQtyInCart = existingItem ? existingItem.qty : 0;

        if (currentQtyInCart >= currentStock) {
            alert("လက်ကျန် Stock မလုံလောက်တော့ပါ!");
            return;
        }

        if (existingItem) {
            existingItem.qty++;
        } else {
            cart.push({ id, name, price, qty: 1 });
        }
        renderCart();
    }

    function removeFromCart(id) {
        cart = cart.filter(i => i.id !== id);
        renderCart();
    }

    function renderCart() {
        const cartList = document.getElementById('cart-items');
        cartList.innerHTML = '';
        cart.forEach(item => {
            cartList.innerHTML += `
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-0 mb-2 bg-transparent">
                    <div style="max-width: 60%;">
                        <div class="fw-bold small text-truncate">${item.name}</div>
                        <small class="text-muted">${item.price.toLocaleString()} x ${item.qty}</small>
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="fw-bold me-2 text-dark small">${(item.price * item.qty).toLocaleString()}</span>
                        <button class="btn btn-sm text-danger p-0" onclick="removeFromCart('${item.id}')"><i class="fa-solid fa-trash-can"></i></button>
                    </div>
                </li>
            `;
        });
        document.getElementById('cart-count').innerText = cart.length;
        updateCartUI();
    }

    function updateCartUI() {
        let subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        let discPercent = parseFloat(document.getElementById('discount-input').value) || 0;
        let taxPercent = parseFloat(document.getElementById('tax-input').value) || 0;
        let discAmount = subtotal * (discPercent / 100);
        let taxAmount = (subtotal - discAmount) * (taxPercent / 100);
        let finalTotal = (subtotal - discAmount) + taxAmount;

        document.getElementById('subtotal-display').innerText = subtotal.toLocaleString() + " MMK";
        document.getElementById('discount-display').innerText = "- " + discAmount.toLocaleString() + " MMK";
        document.getElementById('tax-display').innerText = "+ " + taxAmount.toLocaleString() + " MMK";
        document.getElementById('total-amount').innerText = finalTotal.toLocaleString() + " MMK";
    }

    // --- Checkout Logic ---
    function openPaymentModal() {
        if (cart.length === 0) return alert("Cart is empty!");
        new bootstrap.Modal(document.getElementById('paymentModal')).show();
    }

    function confirmPayment() {
        const payModalEl = document.getElementById('paymentModal');
        const payModal = bootstrap.Modal.getInstance(payModalEl);
        payModal.hide();

        const selectedPayType = document.querySelector('input[name="payType"]:checked').value;
        processCheckout(selectedPayType);
    }

    function processCheckout(payMethod) {
        const discPercent = parseFloat(document.getElementById('discount-input').value) || 0;
        const taxPercent = parseFloat(document.getElementById('tax-input').value) || 0;
        
        // ၁။ Voucher ID အသစ်တစ်ခု generate လုပ်ခြင်း
        const newVoucherId = 'V-' + Date.now().toString().slice(-8); 

        // ၂။ Voucher Modal ထဲမှာ ID နဲ့ Date ထည့်ခြင်း
        document.getElementById('display-voucher-id').innerText = newVoucherId;
        document.getElementById('receipt-date').innerText = new Date().toLocaleString();
        document.getElementById('receipt-paytype').innerText = payMethod;
        
        const receiptItems = document.getElementById('receipt-items');
        receiptItems.innerHTML = '';
        
        cart.forEach(i => {
            receiptItems.innerHTML += `
                <div class="d-flex justify-content-between mb-1">
                    <span style="max-width: 70%;">${i.name} x ${i.qty}</span>
                    <span>${(i.price * i.qty).toLocaleString()}</span>
                </div>`;
        });

        let subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        let discAmt = subtotal * (discPercent / 100);
        let taxAmt = (subtotal - discAmt) * (taxPercent / 100);
        let total = (subtotal - discAmt) + taxAmt;

        document.getElementById('receipt-subtotal').innerText = subtotal.toLocaleString();
        document.getElementById('receipt-discount').innerText = "- " + discAmt.toLocaleString();
        document.getElementById('receipt-tax').innerText = taxAmt.toLocaleString();
        document.getElementById('receipt-total').innerText = total.toLocaleString() + " MMK";

        // ၃။ Voucher Modal ကို ပြခြင်း
        new bootstrap.Modal(document.getElementById('receiptModal')).show();

        // ၄။ Database ထဲရောက်ဖို့ Socket ပို့ခြင်း (voucherId ပါဝင်သည်)
        socket.emit('process-sale', { 
            voucherId: newVoucherId,
            cart: cart, 
            discount: discPercent, 
            tax: taxPercent,
            sellerName: "<%= user.username %>",
            paymentMethod: payMethod 
        });
    }

    function printReceipt() {
        const content = document.getElementById('printableReceipt').innerHTML;
        const win = window.open('', '', 'height=600,width=400');
        win.document.write('<html><head><title>Print Voucher</title>');
        win.document.write('<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">');
        win.document.write('<style>body { padding: 20px; font-family: "Courier New", monospace; }</style></head><body>');
        win.document.write(content);
        win.document.write('</body></html>');
        
        // Print ပြီးရင် Cart ရှင်းမယ်
        setTimeout(() => { 
            win.print(); 
            win.close(); 
            cart = [];
            renderCart();
            bootstrap.Modal.getInstance(document.getElementById('receiptModal')).hide();
        }, 700);
    }

    function searchProduct() {
        let input = document.getElementById('productSearch').value.toLowerCase();
        let rows = document.querySelectorAll('#productTable tbody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(input) ? '' : 'none';
        });
    }

    socket.on('stock-updated', (updates) => {
        updates.forEach(u => {
            const el = document.getElementById(`stock-${u.id}`);
            if (el) {
                el.innerText = u.newStock;
                if (u.newStock < 10) {
                    el.classList.remove('bg-soft-info', 'text-info', 'border-info');
                    el.classList.add('bg-danger');
                } else {
                    el.classList.add('bg-soft-info', 'text-info', 'border-info');
                    el.classList.remove('bg-danger');
                }
            }
        });
    });
</script>

<style>
    .bg-soft-info { background-color: #e0f7fa; }
    .bg-light { background-color: #f8f9fa !important; }
    .border-dashed { border-style: dashed !important; }
    .table thead th { font-size: 0.7rem; letter-spacing: 1px; text-transform: uppercase; }
    .object-fit-cover { object-fit: cover; }
    
    @media (max-width: 768px) {
        .sticky-md-top { position: static !important; }
        .container-fluid { padding-bottom: 20px; }
    }
</style>

<%- include('partials/footer') %>