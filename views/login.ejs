<%- include('partials/header') %>

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.3);
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .login-card:hover {
        transform: translateY(-5px);
    }

    .login-header {
        background: #4e54c8;
        background: -webkit-linear-gradient(to right, #8f94fb, #4e54c8);
        background: linear-gradient(to right, #8f94fb, #4e54c8);
        padding: 40px;
        color: white;
        text-align: center;
    }

    .login-header i {
        font-size: 50px;
        margin-bottom: 15px;
        filter: drop-shadow(0 5px 15px rgba(0,0,0,0.2));
    }

    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #ddd;
        background-color: #f8f9fa;
        transition: all 0.3s;
    }

    .form-control:focus {
        box-shadow: 0 0 10px rgba(78, 84, 200, 0.2);
        border-color: #4e54c8;
        background-color: #fff;
    }

    .btn-login {
        background: linear-gradient(to right, #4e54c8, #8f94fb);
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

    .btn-login:hover {
        box-shadow: 0 5px 15px rgba(78, 84, 200, 0.4);
        transform: scale(1.02);
        color: white;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-radius: 10px 0 0 10px;
        border-right: none;
        color: #4e54c8;
    }

    .form-control-with-icon {
        border-left: none;
        border-radius: 0 10px 10px 0;
    }

    .error-shake {
        animation: shake 0.5s;
    }

    @keyframes shake {
        0%, 100% {transform: translateX(0);}
        25% {transform: translateX(-10px);}
        75% {transform: translateX(10px);}
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="login-card shadow">
                <div class="login-header">
                    <i class="fas fa-user-shield"></i>
                    <h3 class="fw-bold mb-0">SMART POS</h3>
                    <p class="small opacity-75">Sign in to start your session</p>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <% if(error) { %> 
                        <div class="alert alert-danger border-0 small text-center mb-4 error-shake" style="border-radius: 10px;">
                            <i class="fas fa-exclamation-circle me-1"></i> <%= error %>
                        </div> 
                    <% } %>

                    <form action="/login" method="POST">
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">USERNAME</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
                                <input type="text" name="username" class="form-control form-control-with-icon" placeholder="Enter your username" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">PASSWORD</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-key text-muted"></i></span>
                                <input type="password" name="password" class="form-control form-control-with-icon" placeholder="••••••••" required>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-login w-100 mb-3 text-white">
                            LOGIN NOW <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                        
                        <div class="text-center">
                            <a href="/login" class="text-decoration-none small text-muted">Forgot Password?</a>
                        </div>

                    </form>
                </div>
            </div>
            
            <%- include('partials/footer') %>
        </div>
    </div>
</div>

